<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.github.xesam.android.timer.example.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding">

        <!-- ══ Header ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header"
            android:paddingStart="@dimen/card_inner_padding"
            android:paddingEnd="@dimen/card_inner_padding"
            android:paddingTop="@dimen/header_padding_v"
            android:paddingBottom="@dimen/header_padding_v">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/header_title"
                android:textColor="@color/white"
                android:textSize="@dimen/header_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/header_subtitle"
                android:textColor="#E0FFFFFF"
                android:textSize="@dimen/header_subtitle" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/section_gap" />

        <!-- ════════════════════ JAVA API ════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_java"
            android:paddingBottom="@dimen/card_inner_padding">

            <!-- 标题条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_header_java"
                android:paddingStart="@dimen/card_inner_padding"
                android:paddingEnd="@dimen/card_inner_padding"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/java_section_title"
                    android:textColor="@color/white"
                    android:textSize="@dimen/section_title_bar_text"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/java_section_subtitle"
                    android:textColor="#E6FFFFFF"
                    android:textSize="@dimen/section_subtitle" />
            </LinearLayout>

            <!-- 内容区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/card_inner_padding"
                android:paddingEnd="@dimen/card_inner_padding"
                android:paddingTop="@dimen/card_inner_padding">

                <!-- ── AndroidTimer 卡片 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/card_elevation"
                    android:padding="@dimen/card_inner_padding">

                    <!-- 卡片头：标题 + chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AndroidTimer"
                            android:textColor="@color/java_primary"
                            android:textSize="@dimen/component_title"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Java"
                            android:text="@string/chip_periodic" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Java"
                            android:text="@string/chip_pause_resume" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/android_timer_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/component_desc" />

                    <!-- 状态面板 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_status"
                        android:padding="@dimen/status_panel_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/dot_timer_java"
                                android:layout_width="@dimen/state_dot_size"
                                android:layout_height="@dimen/state_dot_size"
                                android:background="@drawable/bg_state_dot" />

                            <TextView
                                android:id="@+id/text_timer_java_state"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/state_idle"
                                android:textColor="@color/status_panel_text"
                                android:textSize="@dimen/status_label"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="已运行"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_timer_java"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_panel_text"
                            android:textSize="@dimen/status_value"
                            android:textStyle="bold"
                            tools:text="0 ms" />
                    </LinearLayout>

                    <!-- 操作按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_timer_start"
                            style="@style/Widget.Demo.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_start"
                            app:backgroundTint="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_timer_pause"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_pause"
                            android:textColor="@color/java_primary"
                            app:strokeColor="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_timer_resume"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_resume"
                            android:textColor="@color/java_primary"
                            app:strokeColor="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_timer_cancel"
                            style="@style/Widget.Demo.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_cancel" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── CountDownTimer 卡片 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_gap"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/card_elevation"
                    android:padding="@dimen/card_inner_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="CountDownTimer"
                            android:textColor="@color/java_primary"
                            android:textSize="@dimen/component_title"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Java"
                            android:text="@string/chip_countdown" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Java"
                            android:text="@string/chip_on_finish" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/count_down_timer_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/component_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_status"
                        android:padding="@dimen/status_panel_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/dot_countdown_java"
                                android:layout_width="@dimen/state_dot_size"
                                android:layout_height="@dimen/state_dot_size"
                                android:background="@drawable/bg_state_dot" />

                            <TextView
                                android:id="@+id/text_countdown_java_state"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/state_idle"
                                android:textColor="@color/status_panel_text"
                                android:textSize="@dimen/status_label"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="剩余"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_countdown_java"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_panel_text"
                            android:textSize="@dimen/status_value"
                            android:textStyle="bold"
                            tools:text="5000 ms" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_countdown_start"
                            style="@style/Widget.Demo.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_start"
                            app:backgroundTint="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_countdown_pause"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_pause"
                            android:textColor="@color/java_primary"
                            app:strokeColor="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_countdown_resume"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_resume"
                            android:textColor="@color/java_primary"
                            app:strokeColor="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_countdown_cancel"
                            style="@style/Widget.Demo.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_cancel" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── AndroidTick 卡片 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_gap"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/card_elevation"
                    android:padding="@dimen/card_inner_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="AndroidTick"
                            android:textColor="@color/java_primary"
                            android:textSize="@dimen/component_title"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Java"
                            android:text="@string/chip_single" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Java"
                            android:text="@string/chip_debounce" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/android_tick_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/component_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_status"
                        android:padding="@dimen/status_panel_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="累计触发"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_tick_java"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_panel_text"
                            android:textSize="@dimen/status_value"
                            android:textStyle="bold"
                            tools:text="count: 0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_tick_start"
                            style="@style/Widget.Demo.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_tick"
                            app:backgroundTint="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_tick_force"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_force_tick"
                            android:textColor="@color/java_primary"
                            app:strokeColor="@color/java_primary" />

                        <Button
                            android:id="@+id/btn_tick_cancel"
                            style="@style/Widget.Demo.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_cancel" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/section_gap" />

        <!-- ════════════════════ KOTLIN API ════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_kotlin"
            android:paddingBottom="@dimen/card_inner_padding">

            <!-- 标题条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_section_header_kotlin"
                android:paddingStart="@dimen/card_inner_padding"
                android:paddingEnd="@dimen/card_inner_padding"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/kt_section_title"
                    android:textColor="@color/white"
                    android:textSize="@dimen/section_title_bar_text"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/kt_section_subtitle"
                    android:textColor="#E6FFFFFF"
                    android:textSize="@dimen/section_subtitle" />
            </LinearLayout>

            <!-- 内容区 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/card_inner_padding"
                android:paddingEnd="@dimen/card_inner_padding"
                android:paddingTop="@dimen/card_inner_padding">

                <!-- ── androidTimer 卡片 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/card_elevation"
                    android:padding="@dimen/card_inner_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="androidTimer"
                            android:textColor="@color/kt_primary"
                            android:textSize="@dimen/component_title"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Kotlin"
                            android:text="@string/chip_periodic" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Kotlin"
                            android:text="@string/chip_flow" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/kt_android_timer_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/component_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_status"
                        android:padding="@dimen/status_panel_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/dot_timer_kt"
                                android:layout_width="@dimen/state_dot_size"
                                android:layout_height="@dimen/state_dot_size"
                                android:background="@drawable/bg_state_dot" />

                            <TextView
                                android:id="@+id/text_timer_kt_state"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/state_idle"
                                android:textColor="@color/status_panel_text"
                                android:textSize="@dimen/status_label"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="已运行"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_timer_kt_tick"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_panel_text"
                            android:textSize="@dimen/status_value"
                            android:textStyle="bold"
                            tools:text="0 ms" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_kt_timer_start"
                            style="@style/Widget.Demo.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_start"
                            app:backgroundTint="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_timer_pause"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_pause"
                            android:textColor="@color/kt_primary"
                            app:strokeColor="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_timer_resume"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_resume"
                            android:textColor="@color/kt_primary"
                            app:strokeColor="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_timer_cancel"
                            style="@style/Widget.Demo.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_cancel" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── countDownTimer 卡片 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_gap"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/card_elevation"
                    android:padding="@dimen/card_inner_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="countDownTimer"
                            android:textColor="@color/kt_primary"
                            android:textSize="@dimen/component_title"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Kotlin"
                            android:text="@string/chip_countdown" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Kotlin"
                            android:text="@string/chip_flow" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/kt_count_down_timer_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/component_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_status"
                        android:padding="@dimen/status_panel_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/dot_countdown_kt"
                                android:layout_width="@dimen/state_dot_size"
                                android:layout_height="@dimen/state_dot_size"
                                android:background="@drawable/bg_state_dot" />

                            <TextView
                                android:id="@+id/text_countdown_kt_state"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="@string/state_idle"
                                android:textColor="@color/status_panel_text"
                                android:textSize="@dimen/status_label"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="剩余"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_countdown_kt_tick"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_panel_text"
                            android:textSize="@dimen/status_value"
                            android:textStyle="bold"
                            tools:text="5000 ms" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/chip_finish_flow"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_countdown_kt_finish"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/state_running"
                            android:textSize="@dimen/status_label"
                            android:textStyle="bold"
                            tools:text="finished ×0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_kt_countdown_start"
                            style="@style/Widget.Demo.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_start"
                            app:backgroundTint="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_countdown_pause"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_pause"
                            android:textColor="@color/kt_primary"
                            app:strokeColor="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_countdown_resume"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_resume"
                            android:textColor="@color/kt_primary"
                            app:strokeColor="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_countdown_cancel"
                            style="@style/Widget.Demo.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_cancel" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── androidTick 卡片 ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/card_gap"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:elevation="@dimen/card_elevation"
                    android:padding="@dimen/card_inner_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="androidTick"
                            android:textColor="@color/kt_primary"
                            android:textSize="@dimen/component_title"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Kotlin"
                            android:text="@string/chip_single" />

                        <TextView
                            style="@style/Widget.Demo.Chip.Kotlin"
                            android:text="@string/chip_dsl" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/kt_android_tick_desc"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="@dimen/component_desc" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_status"
                        android:padding="@dimen/status_panel_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="累计触发"
                            android:textColor="#99ECEFF1"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/text_tick_kt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAlignment="center"
                            android:fontFamily="monospace"
                            android:textColor="@color/status_panel_text"
                            android:textSize="@dimen/status_value"
                            android:textStyle="bold"
                            tools:text="count: 0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btn_kt_tick_start"
                            style="@style/Widget.Demo.Button.Primary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/btn_tick"
                            app:backgroundTint="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_tick_force"
                            style="@style/Widget.Demo.Button.Secondary"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_force_tick"
                            android:textColor="@color/kt_primary"
                            app:strokeColor="@color/kt_primary" />

                        <Button
                            android:id="@+id/btn_kt_tick_cancel"
                            style="@style/Widget.Demo.Button.Danger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:text="@string/btn_cancel" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
