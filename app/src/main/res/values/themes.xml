<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.AndroidUnits" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.AndroidUnits.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- 主操作按钮（start / tick）：填充色，在布局中按区设置 app:backgroundTint -->
    <style name="Widget.Demo.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 次操作按钮（pause / resume / force tick）：描边，在布局中按区设置 app:strokeColor 与文字色 -->
    <style name="Widget.Demo.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 危险操作按钮（cancel）：红色描边 + 红色文字 -->
    <style name="Widget.Demo.Button.Danger" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">@dimen/button_text_size</item>
        <item name="android:minHeight">@dimen/button_min_height</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:insetTop">4dp</item>
        <item name="android:insetBottom">4dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="strokeColor">@color/danger</item>
        <item name="android:textColor">@color/danger</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- 特性标签（chip）文本样式 -->
    <style name="Widget.Demo.Chip" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:layout_marginStart">6dp</item>
        <item name="android:textSize">@dimen/chip_text</item>
    </style>

    <style name="Widget.Demo.Chip.Java">
        <item name="android:background">@drawable/bg_chip_java</item>
        <item name="android:textColor">@color/java_chip_text</item>
    </style>

    <style name="Widget.Demo.Chip.Kotlin">
        <item name="android:background">@drawable/bg_chip_kotlin</item>
        <item name="android:textColor">@color/kt_chip_text</item>
    </style>

    <style name="Theme.AndroidUnits.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.AndroidUnits.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
